{
  "runtime.version": "LuaJIT",
  "workspace.library": [
    "${3rd}/luv/library",
    "${3rd}/busted/library"
  ],
  "workspace.checkThirdParty": false,
  "workspace.ignoreDir": [
    "references",
    ".git"
  ],
  "diagnostics.globals": [
    "vim",
    "describe",
    "it",
    "before_each",
    "after_each",
    "setup",
    "teardown"
  ],
  "diagnostics.disable": [
    "trailing-space",
    "missing-fields"
  ],
  "completion.workspaceWord": true
}
